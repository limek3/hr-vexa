BOT_TOKEN=
BOT_PROXY_URL=

DATABASE_URL=

TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=
TELEGRAM_AUTO_JOIN_SOURCES=true
TELEGRAM_SOURCE_REFRESH_INTERVAL_SECONDS=60
TELEGRAM_JOIN_DELAY_SECONDS=12
TELEGRAM_MAX_JOINS_PER_CYCLE=2

MAX_SOURCES_PER_SEARCH=10

# Comma-separated Telegram user IDs allowed to use /unblock and /blocked_count.
# Leave empty to disable both admin commands.
ADMIN_TELEGRAM_IDS=

# How many days to keep terminal (blocked/failed) notification delivery
# records before the daily cleanup job removes them. "sent" records are
# never auto-deleted.
NOTIFICATION_DELIVERY_RETENTION_DAYS=30

APP_ENV=production
LOG_LEVEL=INFO
